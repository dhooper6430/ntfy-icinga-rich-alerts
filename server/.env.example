# Server stack configuration. Copy to .env, fill in, and KEEP IT OUT OF GIT (.gitignore covers it).

# --- Secrets ----------------------------------------------------------------------------------
# Shared HMAC secret — MUST match the dispatcher's broker.shared_secret (config.yml) on the
# Icinga master. Authorises Ack/Downtime action callbacks + signed graph-fetch URLs.
# Generate one with: openssl rand -hex 32
BROKER_SHARED_SECRET=replace-me

# Password for the scoped Icinga2 ApiUser "ntfy-broker"
# (permissions: actions/acknowledge-problem + actions/schedule-downtime).
# MUST match the password on the "ntfy-broker" ApiUser in your Icinga config.
ICINGA_API_PASSWORD=replace-me

# --- Icinga API endpoint (used by the broker) -------------------------------------------------
# Where the broker reaches your Icinga2 API (default port 5665).
ICINGA_API_URL=https://icinga.example.com:5665
ICINGA_API_USER=ntfy-broker
# 1 = skip TLS verification of the Icinga API (self-signed certs); 0 = verify (provide a CA).
ICINGA_API_INSECURE=1

# --- Compose / runtime --------------------------------------------------------------------------
# Pin a specific ntfy image tag for reproducible deploys (https://hub.docker.com/r/binwiederhier/ntfy/tags).
NTFY_VERSION=latest
# Host path for persistent data (ntfy db + graph cache). Defaults to ./data if unset.
NTFY_DATA_PATH=./data
# Which host interface the published ports bind to. Keep on localhost if your reverse proxy is
# on the same host; set to 0.0.0.0 to expose directly (then secure it yourself).
NTFY_BIND=127.0.0.1
BROKER_BIND=127.0.0.1
